# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
.env
.envrc

# Jupyter
.ipynb_checkpoints/
*.ipynb.bak
profile_default/
ipython_config.py

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs and runtime artifacts
logs/
*.log
nohup.out
wandb/
runs/
checkpoints/

# === Project-specific ===

# Raw Vibe Sim exports are huge — keep them out of the repo.
# The folder structure (with .gitkeep) is committed; the contents are not.
data/*/images/*
data/*/labels/*
!data/*/images/.gitkeep
!data/*/labels/.gitkeep
data/merged/
data/predictions/
data/real_reference/images/*
data/real_reference/labels/*
!data/real_reference/images/.gitkeep
!data/real_reference/labels/.gitkeep

# Trained model weights and intermediate training artifacts
runs/
checkpoints/*.pt
checkpoints/*.onnx
checkpoints/*.engine
*.pt
*.onnx
*.engine

# Generated analysis artifacts (the notebooks can be re-run; the PNGs are large)
strategy/*.png
docs/*.png

# Generated submission bundles
submission/
submissions/
predictions/

# Generated .npy caches
*.npy
!strategy/*.npy
